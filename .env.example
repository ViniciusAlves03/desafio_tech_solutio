# --- POSTGRES CONFIGURATION ---
POSTGRES_DB=products_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_PORT_EXTERNAL=5432

# URL used by the application to connect to the database container
# use 'postgres' as the host because it is the service name in docker-compose
DATABASE_URL=postgresql://admin:admin@postgres:5432/products_db

# --- REDIS CONFIGURATION ---
REDIS_PORT=6379
# URL used by the application and worker to connect to the redis container
REDIS_URL=redis://redis:6379/0

# --- SECURITY ---
# Your custom 64-character hex key for JWT signing
JWT_SECRET_KEY=6f9c8a9b3d2e1f4a6b8c7d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a

# --- FLASK ---
FLASK_APP=app.app:create_app
FLASK_ENV=development
